@model RetailOptimizationPlatform.ViewModels.AdminLoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login - RetailOptimizationPlatform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-page">
    <main class="auth-shell">
        <section class="auth-panel">
            <div class="auth-brand">
                <div class="brand-icon">D</div>
                <div>
                    <div class="brand-text text-dark">D-inventy</div>
                    <div class="text-muted" style="font-size: 0.85rem;">Admin access</div>
                </div>
            </div>

            <h1 class="auth-title">Inventory Admin Login</h1>
            <p class="auth-copy">Sign in to manage products, orders, low stock alerts, and dashboard analytics.</p>

            <form asp-action="Login" method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.85rem;"></div>

                <div class="form-premium-group">
                    <label asp-for="Email" class="form-premium-label">Admin Email</label>
                    <input asp-for="Email" class="form-premium-control" autocomplete="username" placeholder="admin@retail.local" />
                    <span asp-validation-for="Email" class="text-danger" style="font-size: 0.8rem;"></span>
                </div>

                <div class="form-premium-group">
                    <label asp-for="Password" class="form-premium-label">Password</label>
                    <input asp-for="Password" class="form-premium-control" autocomplete="current-password" placeholder="Enter password" />
                    <span asp-validation-for="Password" class="text-danger" style="font-size: 0.8rem;"></span>
                </div>

                <button type="submit" class="btn-premium btn-premium-primary w-100 justify-content-center mt-2">
                    Sign in
                </button>
            </form>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
