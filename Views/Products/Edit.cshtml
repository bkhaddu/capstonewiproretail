@model RetailOptimizationPlatform.Models.Product
@{
    ViewData["Title"] = "Edit Product Information";
}

<div class="form-premium-card reveal">
    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center icon-emerald mb-2" style="width: 50px; height: 50px; border-radius: 12px; font-size: 1.5rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4Z"></path></svg>
        </div>
        <h3 class="fw-bold text-dark m-0" style="font-family: 'Space Grotesk', sans-serif;">Adjust Product Details</h3>
        <p class="text-muted" style="font-size: 0.85rem;">Modify active pricing, current stock count, or reorder levels.</p>
    </div>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="ProductId" />

        <div class="form-premium-group">
            <label class="form-premium-label">Product Name</label>
            <input asp-for="ProductName" class="form-premium-control" required />
            <span asp-validation-for="ProductName" class="text-danger" style="font-size: 0.8rem;"></span>
        </div>

        <div class="form-premium-group">
            <label class="form-premium-label">Category</label>
            <input asp-for="Category" class="form-premium-control" required />
            <span asp-validation-for="Category" class="text-danger" style="font-size: 0.8rem;"></span>
        </div>

        <div class="row">
            <div class="col-md-6 form-premium-group">
                <label class="form-premium-label">Unit Price (₹)</label>
                <input asp-for="Price" type="number" step="0.01" class="form-premium-control" required />
                <span asp-validation-for="Price" class="text-danger" style="font-size: 0.8rem;"></span>
            </div>

            <div class="col-md-6 form-premium-group">
                <label class="form-premium-label">Stock Quantity</label>
                <input asp-for="StockQuantity" type="number" class="form-premium-control" required />
                <span asp-validation-for="StockQuantity" class="text-danger" style="font-size: 0.8rem;"></span>
            </div>
        </div>

        <div class="form-premium-group">
            <label class="form-premium-label">Reorder Safety Level</label>
            <input asp-for="ReorderLevel" type="number" class="form-premium-control" required />
            <span asp-validation-for="ReorderLevel" class="text-danger" style="font-size: 0.8rem;"></span>
        </div>

        <div class="d-flex gap-2 justify-content-end mt-4">
            <a asp-action="Index" class="btn-premium btn-premium-secondary">Discard Changes</a>
            <button type="submit" class="btn-premium btn-premium-success">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                Apply Updates
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}