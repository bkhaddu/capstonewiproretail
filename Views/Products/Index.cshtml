@model IEnumerable<RetailOptimizationPlatform.Models.Product>
@{
    ViewData["Title"] = "Executive Inventory Dashboard";
    var totalProducts = Model.Count();
    var lowStockCount = Model.Count(p => p.StockQuantity <= p.ReorderLevel);
    var outOfStockCount = Model.Count(p => p.StockQuantity == 0);
    var totalValue = Model.Sum(p => p.Price * p.StockQuantity);
}

<!-- Metrics KPI Grid -->
<div class="metrics-row reveal">
    <a asp-controller="Products" asp-action="Index" class="metric-card text-decoration-none">
        <div class="metric-data">
            <span class="metric-label">Total Inventory Value</span>
            <span class="metric-number">₹@totalValue.ToString("N0")</span>
        </div>
        <div class="metric-icon-box icon-blue">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h12M6 8h12M6 3a6 6 0 0 1 6 6H6m6 0a6 6 0 0 1-6 6h2l7 7"/></svg>
        </div>
    </a>

    <a asp-controller="Products" asp-action="Index" class="metric-card text-decoration-none">
        <div class="metric-data">
            <span class="metric-label">Total Products</span>
            <span class="metric-number">@totalProducts</span>
        </div>
        <div class="metric-icon-box icon-emerald">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
        </div>
    </a>

    <a asp-controller="Products" asp-action="LowStock" class="metric-card text-decoration-none">
        <div class="metric-data">
            <span class="metric-label">Low Stock items</span>
            <span class="metric-number text-warning">@lowStockCount</span>
        </div>
        <div class="metric-icon-box icon-amber">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        </div>
    </a>

    <a asp-controller="Orders" asp-action="History" class="metric-card text-decoration-none">
        <div class="metric-data">
            <span class="metric-label">Sales Operations</span>
            <span class="metric-number" id="kpi-orders-count">--</span>
        </div>
        <div class="metric-icon-box icon-rose">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        </div>
    </a>
</div>

<!-- Charts Panel Row -->
<div class="charts-grid reveal">
    <!-- Sales / Orders Area Trend -->
    <div class="chart-card">
        <div class="chart-header">
            <h3 class="chart-title">Sales & order volume trend</h3>
            <span class="badge-custom badge-custom-info">Live Tracker</span>
        </div>
        <div class="chart-wrapper" style="height: 300px;">
            <canvas id="salesTrendChart"></canvas>
        </div>
    </div>

    <!-- Category Redistribution (Doughnut) -->
    <div class="chart-card">
        <div class="chart-header">
            <h3 class="chart-title">Category breakdown</h3>
        </div>
        <div class="chart-wrapper" style="height: 300px; display: flex; align-items: center; justify-content: center;">
            <canvas id="categoryChart"></canvas>
        </div>
    </div>
</div>

<!-- Stock Levels vs Reorder Target (Full width Bar Chart) -->
<div class="chart-card reveal mb-4">
    <div class="chart-header">
        <h3 class="chart-title">Stock levels vs. reorder levels</h3>
        <span class="badge-custom badge-custom-warning">Inventory Status Indicator</span>
    </div>
    <div class="chart-wrapper" style="height: 250px;">
        <canvas id="stockBarChart"></canvas>
    </div>
</div>

<!-- Products Table List -->
<div class="premium-table-card reveal">
    <div class="table-title-row">
        <div>
            <h3 class="chart-title" style="font-size: 1.25rem;">Active Inventory Catalog</h3>
            <p class="text-muted m-0" style="font-size: 0.82rem;">Create, edit, and audit live products and their stock thresholds.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn-premium btn-premium-primary btn-premium-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Add Product
            </a>
            <a asp-action="LowStock" class="btn-premium btn-premium-secondary btn-premium-sm">
                Low Stock Alerts
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="premium-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock status</th>
                    <th>Reorder level</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    var isLow = product.StockQuantity <= product.ReorderLevel;
                    var isOut = product.StockQuantity == 0;
                    
                    <tr>
                        <td class="fw-semibold text-dark">@product.ProductName</td>
                        <td>
                            <span class="badge-custom badge-custom-info">@product.Category</span>
                        </td>
                        <td class="fw-semibold">₹@product.Price.ToString("N2")</td>
                        <td>
                            @if (isOut)
                            {
                                <span class="badge-custom badge-custom-danger">Out of Stock</span>
                            }
                            else if (isLow)
                            {
                                <span class="badge-custom badge-custom-warning">Low Stock (@product.StockQuantity)</span>
                            }
                            else
                            {
                                <span class="badge-custom badge-custom-success">In Stock (@product.StockQuantity)</span>
                            }
                        </td>
                        <td>@product.ReorderLevel units</td>
                        <td>
                            <div class="d-flex justify-content-end gap-1">
                                <button onclick="checkProductStock(@product.ProductId)" class="btn-premium btn-premium-secondary btn-premium-sm" style="padding: 0.25rem 0.6rem;">
                                    Verify Stock
                                </button>
                                <a asp-action="Edit" asp-route-id="@product.ProductId" class="btn-premium btn-premium-success btn-premium-sm" style="padding: 0.25rem 0.6rem;">
                                    Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@product.ProductId" class="btn-premium btn-premium-danger btn-premium-sm" style="padding: 0.25rem 0.6rem;" onclick="return confirm('Are you sure you want to delete this product?');">
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Beautiful Custom Modal for Stock Check -->
<div class="modal fade" id="stockCheckModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content stock-check-result" style="border-radius: 18px; border: none; box-shadow: var(--shadow-premium);">
            <div class="modal-header" style="border-bottom: 1px solid var(--border-color); padding: 1.25rem 1.5rem;">
                <h5 class="modal-title fw-bold text-dark" style="font-family: 'Space Grotesk', sans-serif;">Live Inventory Audit</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem;">
                <div class="text-center mb-3">
                    <div id="modal-status-icon" class="d-inline-flex align-items-center justify-content-center" style="width: 54px; height: 54px; border-radius: 50%; font-size: 1.6rem; margin-bottom: 1rem;">
                        <!-- Dynamically filled -->
                    </div>
                    <h4 id="modal-product-name" class="fw-bold text-dark mb-1" style="font-family: 'Space Grotesk', sans-serif;">--</h4>
                    <p id="modal-product-category" class="text-muted m-0" style="font-size: 0.85rem;">--</p>
                </div>
                
                <div class="d-flex justify-content-between align-items-center p-2 mb-2 bg-light rounded-3" style="font-size: 0.95rem;">
                    <span class="text-muted fw-semibold">Current Stock Level:</span>
                    <span id="modal-stock-qty" class="fw-bold text-dark">0 units</span>
                </div>
                <div class="d-flex justify-content-between align-items-center p-2 bg-light rounded-3" style="font-size: 0.95rem;">
                    <span class="text-muted fw-semibold">Availability Status:</span>
                    <span id="modal-status-badge">--</span>
                </div>
            </div>
            <div class="modal-footer" style="border-top: none; padding: 1rem 1.5rem 1.5rem 1.5rem;">
                <button type="button" class="btn-premium btn-premium-primary w-100 justify-content-center" data-bs-dismiss="modal">Close Audit</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // High-end Charting Script utilizing the dashboard-data API
        document.addEventListener("DOMContentLoaded", function () {
            fetch('/api/inventory/dashboard-data')
                .then(response => response.json())
                .then(data => {
                    // Update Orders KPI
                    if (data.metrics) {
                        document.getElementById('kpi-orders-count').innerText = data.metrics.totalOrders;
                    }

                    // 1. DOUGHNUT CHART (Category Redistribution)
                    const categoriesData = data.categories || [];
                    const categoryLabels = categoriesData.map(c => c.category);
                    const categoryCounts = categoriesData.map(c => c.count);

                    const ctxCategory = document.getElementById('categoryChart').getContext('2d');
                    new Chart(ctxCategory, {
                        type: 'doughnut',
                        data: {
                            labels: categoryLabels,
                            datasets: [{
                                data: categoryCounts,
                                backgroundColor: [
                                    '#3b82f6', // Cobalt
                                    '#10b981', // Emerald
                                    '#f59e0b', // Amber
                                    '#8b5cf6', // Violet
                                    '#ec4899', // Pink
                                    '#06b6d4'  // Cyan
                                ],
                                borderWidth: 4,
                                borderColor: '#ffffff',
                                hoverOffset: 8
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: 'bottom',
                                    labels: {
                                        boxWidth: 12,
                                        font: {
                                            family: 'Outfit',
                                            size: 11,
                                            weight: '500'
                                        },
                                        color: '#475569'
                                    }
                                },
                                tooltip: {
                                    backgroundColor: '#0f172a',
                                    titleFont: { family: 'Space Grotesk', size: 13, weight: 'bold' },
                                    bodyFont: { family: 'Outfit', size: 12 },
                                    padding: 10,
                                    cornerRadius: 8,
                                    displayColors: true
                                }
                            },
                            cutout: '72%'
                        }
                    });

                    // 2. LINE AREA CHART (Sales Trend)
                    const trendData = data.orderTrend || [];
                    const trendLabels = trendData.map(t => t.date);
                    const trendSales = trendData.map(t => t.totalAmount);
                    const trendOrders = trendData.map(t => t.count);

                    const ctxSales = document.getElementById('salesTrendChart').getContext('2d');
                    
                    // Create gradient fill
                    const blueGrad = ctxSales.createLinearGradient(0, 0, 0, 300);
                    blueGrad.addColorStop(0, 'rgba(37, 99, 235, 0.25)');
                    blueGrad.addColorStop(1, 'rgba(37, 99, 235, 0.0)');

                    new Chart(ctxSales, {
                        type: 'line',
                        data: {
                            labels: trendLabels,
                            datasets: [{
                                label: 'Revenue (₹)',
                                data: trendSales,
                                borderColor: '#2563eb',
                                borderWidth: 3,
                                pointBackgroundColor: '#2563eb',
                                pointBorderColor: '#ffffff',
                                pointBorderWidth: 2,
                                pointRadius: 4,
                                pointHoverRadius: 6,
                                fill: true,
                                backgroundColor: blueGrad,
                                tension: 0.4
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: '#0f172a',
                                    titleFont: { family: 'Space Grotesk', size: 13, weight: 'bold' },
                                    bodyFont: { family: 'Outfit', size: 12 },
                                    padding: 12,
                                    cornerRadius: 8,
                                    callbacks: {
                                        label: function(context) {
                                            return ` Revenue: ₹${context.raw.toLocaleString()}`;
                                        }
                                    }
                                }
                            },
                            scales: {
                                x: {
                                    grid: { display: false },
                                    ticks: {
                                        font: { family: 'Outfit', size: 11 },
                                        color: '#94a3b8'
                                    }
                                },
                                y: {
                                    border: { dash: [5, 5] },
                                    grid: { color: '#e2e8f0' },
                                    ticks: {
                                        font: { family: 'Outfit', size: 11 },
                                        color: '#94a3b8',
                                        callback: function(value) {
                                            return '₹' + value.toLocaleString();
                                        }
                                    }
                                }
                            }
                        }
                    });

                    // 3. BAR CHART (Stock vs Reorder)
                    const stockLevels = data.stockLevels || [];
                    const productNames = stockLevels.map(s => s.productName);
                    const stockQtys = stockLevels.map(s => s.stockQuantity);
                    const reorderLvl = stockLevels.map(s => s.reorderLevel);

                    const ctxBar = document.getElementById('stockBarChart').getContext('2d');
                    new Chart(ctxBar, {
                        type: 'bar',
                        data: {
                            labels: productNames,
                            datasets: [
                                {
                                    label: 'Current Stock',
                                    data: stockQtys,
                                    backgroundColor: '#3b82f6',
                                    borderRadius: 6,
                                    barPercentage: 0.55,
                                    categoryPercentage: 0.8
                                },
                                {
                                    label: 'Reorder Level',
                                    data: reorderLvl,
                                    backgroundColor: '#cbd5e1',
                                    borderRadius: 6,
                                    barPercentage: 0.55,
                                    categoryPercentage: 0.8
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: 'top',
                                    labels: {
                                        boxWidth: 12,
                                        font: { family: 'Outfit', size: 11, weight: '500' },
                                        color: '#475569'
                                    }
                                },
                                tooltip: {
                                    backgroundColor: '#0f172a',
                                    titleFont: { family: 'Space Grotesk', size: 13, weight: 'bold' },
                                    bodyFont: { family: 'Outfit', size: 12 },
                                    padding: 10,
                                    cornerRadius: 8
                                }
                            },
                            scales: {
                                x: {
                                    grid: { display: false },
                                    ticks: { font: { family: 'Outfit', size: 11 }, color: '#94a3b8' }
                                },
                                y: {
                                    border: { dash: [5, 5] },
                                    grid: { color: '#e2e8f0' },
                                    ticks: { font: { family: 'Outfit', size: 11 }, color: '#94a3b8' }
                                }
                            }
                        }
                    });
                })
                .catch(err => console.error("Error loading dashboard charts:", err));
        });

        // Audit Stock dynamic Modal popup implementation
        function checkProductStock(productId) {
            fetch(`/api/inventory/check/${productId}`)
                .then(res => res.json())
                .then(data => {
                    document.getElementById('modal-product-name').innerText = data.productName;
                    document.getElementById('modal-stock-qty').innerText = `${data.stockQuantity} units`;
                    
                    const catSpan = document.getElementById('modal-product-category');
                    // Find actual product category from the model table or default to 'Active Catalog'
                    catSpan.innerText = 'Product ID: #' + data.productId;

                    const iconBox = document.getElementById('modal-status-icon');
                    const badge = document.getElementById('modal-status-badge');

                    if (data.stockQuantity === 0) {
                        iconBox.className = "d-inline-flex align-items-center justify-content-center icon-rose";
                        iconBox.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>';
                        badge.className = "badge-custom badge-custom-danger";
                        badge.innerText = "Out of Stock - Immediate Attention Required";
                    } else if (data.isLowStock) {
                        iconBox.className = "d-inline-flex align-items-center justify-content-center icon-amber";
                        iconBox.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>';
                        badge.className = "badge-custom badge-custom-warning";
                        badge.innerText = "Low Stock Alert - Place Order Soon";
                    } else {
                        iconBox.className = "d-inline-flex align-items-center justify-content-center icon-emerald";
                        iconBox.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                        badge.className = "badge-custom badge-custom-success";
                        badge.innerText = "Sufficient Stock - Fully Available";
                    }

                    // Display the modal
                    const myModal = new bootstrap.Modal(document.getElementById('stockCheckModal'));
                    myModal.show();
                })
                .catch(err => {
                    console.error("Error auditting stock:", err);
                    alert("Error auditting stock details.");
                });
        }
    </script>
}
