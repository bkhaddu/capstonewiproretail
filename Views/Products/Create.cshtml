@model RetailOptimizationPlatform.Models.Product
@{
    ViewData["Title"] = "Add New Product";
}

<div class="form-premium-card reveal">
    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center icon-blue mb-2" style="width: 50px; height: 50px; border-radius: 12px; font-size: 1.5rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"></rect><rect x="14" y="3" width="7" height="5"></rect><rect x="14" y="12" width="7" height="9"></rect><rect x="3" y="16" width="7" height="5"></rect></svg>
        </div>
        <h3 class="fw-bold text-dark m-0" style="font-family: 'Space Grotesk', sans-serif;">Register New Product</h3>
        <p class="text-muted" style="font-size: 0.85rem;">Specify stock attributes and reorder safety zones for the catalog.</p>
    </div>

    <form asp-action="Create" method="post">
        <div class="form-premium-group">
            <label class="form-premium-label">Product Name</label>
            <input asp-for="ProductName" class="form-premium-control" placeholder="e.g. Mechanical Keyboard" required />
            <span asp-validation-for="ProductName" class="text-danger" style="font-size: 0.8rem;"></span>
        </div>

        <div class="form-premium-group">
            <label class="form-premium-label">Category</label>
            <input asp-for="Category" class="form-premium-control" placeholder="e.g. Electronics, Accessories" required />
            <span asp-validation-for="Category" class="text-danger" style="font-size: 0.8rem;"></span>
        </div>

        <div class="row">
            <div class="col-md-6 form-premium-group">
                <label class="form-premium-label">Unit Price (₹)</label>
                <input asp-for="Price" type="number" step="0.01" class="form-premium-control" placeholder="0.00" required />
                <span asp-validation-for="Price" class="text-danger" style="font-size: 0.8rem;"></span>
            </div>

            <div class="col-md-6 form-premium-group">
                <label class="form-premium-label">Initial Stock Level</label>
                <input asp-for="StockQuantity" type="number" class="form-premium-control" placeholder="0" required />
                <span asp-validation-for="StockQuantity" class="text-danger" style="font-size: 0.8rem;"></span>
            </div>
        </div>

        <div class="form-premium-group">
            <label class="form-premium-label">Reorder Safety Level</label>
            <input asp-for="ReorderLevel" type="number" class="form-premium-control" placeholder="e.g. 5" required />
            <span asp-validation-for="ReorderLevel" class="text-danger" style="font-size: 0.8rem;"></span>
            <small class="text-muted" style="font-size: 0.78rem;">An alert will trigger when inventory stock drops below this number.</small>
        </div>

        <div class="d-flex gap-2 justify-content-end mt-4">
            <a asp-action="Index" class="btn-premium btn-premium-secondary">Cancel</a>
            <button type="submit" class="btn-premium btn-premium-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Save Product
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}