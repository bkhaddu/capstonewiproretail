@model RetailOptimizationPlatform.ViewModels.OrderCreateViewModel
@{
    ViewData["Title"] = "Place Customer Order";
}

<div class="form-premium-card reveal">
    <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center icon-blue mb-2" style="width: 50px; height: 50px; border-radius: 12px; font-size: 1.5rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        </div>
        <h3 class="fw-bold text-dark m-0" style="font-family: 'Space Grotesk', sans-serif;">Place Customer Order</h3>
        <p class="text-muted" style="font-size: 0.85rem;">Instantly capture a sales transaction and dynamically adjust product levels.</p>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.85rem;"></div>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 rounded-3 mb-4" role="alert" style="font-size: 0.9rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            <div>Please review the highlighted order details.</div>
            </div>
        }

        <div class="form-premium-group">
            <label asp-for="CustomerName" class="form-premium-label">Customer Name</label>
            <input asp-for="CustomerName" class="form-premium-control" placeholder="e.g. John Doe" />
            <span asp-validation-for="CustomerName" class="text-danger" style="font-size: 0.8rem;"></span>
        </div>

        <div class="form-premium-group">
            <label asp-for="CustomerEmail" class="form-premium-label">Customer Email</label>
            <input asp-for="CustomerEmail" class="form-premium-control" placeholder="e.g. john.doe@example.com" />
            <span asp-validation-for="CustomerEmail" class="text-danger" style="font-size: 0.8rem;"></span>
        </div>

        <div class="form-premium-group">
            <label asp-for="ProductId" class="form-premium-label">Product Selection</label>
            <select asp-for="ProductId" class="form-premium-control form-select">
                @foreach (var product in ViewBag.Products)
                {
                    <option value="@product.ProductId">
                        @product.ProductName (Available: @product.StockQuantity units) — ₹@product.Price.ToString("N2")
                    </option>
                }
            </select>
            <span asp-validation-for="ProductId" class="text-danger" style="font-size: 0.8rem;"></span>
            <small class="text-muted" style="font-size: 0.78rem;">Live inventory levels are shown. Orders exceeding stock will be rejected.</small>
        </div>

        <div class="form-premium-group">
            <label asp-for="Quantity" class="form-premium-label">Quantity</label>
            <input asp-for="Quantity" type="number" min="1" class="form-premium-control" placeholder="1" />
            <span asp-validation-for="Quantity" class="text-danger" style="font-size: 0.8rem;"></span>
        </div>

        <div class="d-flex gap-2 justify-content-end mt-4">
            <a asp-controller="Products" asp-action="Index" class="btn-premium btn-premium-secondary">Cancel</a>
            <button type="submit" class="btn-premium btn-premium-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                Complete Transaction
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
