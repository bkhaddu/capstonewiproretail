@{
    ViewData["Title"] = "Order Success";
}

<div class="form-premium-card reveal text-center py-5" style="max-width: 500px;">
    <div class="d-inline-flex align-items-center justify-content-center icon-emerald mb-4 stock-check-result" style="width: 72px; height: 72px; border-radius: 50%; font-size: 2.2rem; box-shadow: 0 8px 24px rgba(16, 185, 129, 0.2);">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
    </div>
    
    <h2 class="fw-bold text-dark mb-2" style="font-family: 'Space Grotesk', sans-serif;">Transaction Confirmed</h2>
    <p class="text-muted mb-4" style="font-size: 0.95rem; max-width: 360px; margin: 0 auto;">The customer order has been placed successfully. Live inventory levels have been adjusted automatically.</p>

    <div class="d-flex flex-column gap-2" style="max-width: 280px; margin: 0 auto;">
        <a asp-controller="Products" asp-action="Index" class="btn-premium btn-premium-primary justify-content-center">
            Go to Dashboard
        </a>
        <a asp-controller="Orders" asp-action="History" class="btn-premium btn-premium-secondary justify-content-center">
            View Ledger History
        </a>
    </div>
</div>